# Neon: Dashboard → Connection details → copy pooled connection string
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Optional: local Postgres instead of Neon
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/perspective_os

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional fallback
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite

# Optional: force provider when both keys are set (openai | gemini)
# LLM_PROVIDER=openai
